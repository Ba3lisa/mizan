# Convex deployment URL (auto-generated by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Set these in the Convex Dashboard (Settings > Environment Variables):
#
# ── LLM Providers (at least one required) ──
# Priority: Anthropic > OpenAI > Google > OpenRouter
# The pipeline uses the highest-priority available provider.
# The LLM Council uses ALL configured providers (each casts a vote).
#
# ANTHROPIC_API_KEY=sk-ant-...           # Claude Haiku 4.5
# OPENAI_API_KEY=sk-...                  # GPT-4o-mini
# GOOGLE_AI_API_KEY=AI...                # Gemini 2.0 Flash
# OPENROUTER_API_KEY=sk-or-...           # Any model via OpenRouter
# OPENROUTER_MODEL=meta-llama/llama-4-scout  # Optional: override default model
#
# ── GitHub ──
# GITHUB_TOKEN=ghp_...                   # Issues processing (needs issues:write)
